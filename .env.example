# Copie para .env e ajuste conforme necessário.
# No Vite, só variáveis com prefixo VITE_ chegam ao frontend (e ficam públicas no bundle).

# Servidor de roteamento OSRM.
# DEV: pode usar o demo público abaixo. PRODUÇÃO: rode OSRM próprio ou use um provedor.
VITE_OSRM_URL=https://router.project-osrm.org

# Tiles do mapa. Padrão (se vazio): Carto dark.
# Tema claro: https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
VITE_TILE_URL=https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png
